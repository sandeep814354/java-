static void displayPersonalDetails() {
        // Reading inputs for Personal Details
        String name = sc.next();
        int age = sc.nextInt();
        String gender = sc.next();

        // Displaying Personal Details
        System.out.println("--- Personal Details ---");
        System.out.println("Name : " + name);
        System.out.println("Age : " + age);
        System.out.println("Gender : " + gender);
        System.out.println(); // Adding a blank line for formatting
    }

    static void displayQualificationDetails() {
        // Clearing the buffer before reading strings that might contain spaces
        sc.nextLine(); 
        
        // Reading inputs for Qualification Details
        String qualification = sc.nextLine();
        String college = sc.nextLine();
        int year = sc.nextInt();

        // Displaying Qualification Details
        System.out.println("--- Qualification Details ---");
        System.out.println("Qualification : " + qualification);
        System.out.println("College : " + college);
        System.out.println("Year of Pass : " + year);
    }
