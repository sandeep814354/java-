import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in); // Fixed: System.in, not System.util.in
        
        if (sc.hasNext()) {
            String S = sc.next();
            int n = Integer.parseInt(S);
            int k = S.length(); // This correctly gets the number of digits
            
            if (isArmstrong(n, k)) {
                System.out.println("YES");
            } else {
                System.out.println("NO");
            }
        }
        sc.close();
    }

    static boolean isArmstrong(int n, int k) {
        if (n == 0) return true; // 0 is technically an Armstrong number (0^1 = 0)
        
        long sum = 0;
        int temp = n;
        
        while (temp > 0) {
            int digit = temp % 10;
            
            // Manual power calculation to avoid Math.pow precision issues
            long p = 1;
            for (int i = 0; i < k; i++) {
                p *= digit;
            }
            
            sum += p;
            temp /= 10;
        }
        
        return sum == (long) n;
    }
}
