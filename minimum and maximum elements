import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Read the size of the array
        if (!sc.hasNextInt()) return;
        int n = sc.nextInt();

        // Initialize the array
        int[] a = new int[n];
        for (int i = 0; i < n; i++) {
            a[i] = sc.nextInt();
        }

        // Logic to find Min and Max
        // Start by assuming the first element is both min and max
        int min = a[0];
        int max = a[0];

        for (int i = 1; i < n; i++) {
            if (a[i] < min) {
                min = a[i]; // Update min if current element is smaller
            }
            if (a[i] > max) {
                max = a[i]; // Update max if current element is larger
            }
        }

        // Output the result separated by a space
        System.out.println(min + " " + max);
    }
}
